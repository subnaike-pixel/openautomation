{
  "name": "openautomation",
  "version": "1.0.2",
  "description": "OpenAutomation - Your AI automation workspace",
  "main": "main.js",
  "author": "OpenAutomation",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win --publish never"
  },
  "dependencies": {
    "marked": "^12.0.0",
    "openclaw": "^2026.3.13",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.openautomation.app",
    "productName": "OpenAutomation",
    "copyright": "Copyright © 2026 OpenAutomation",
    "asar": true,
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-splash.js",
      "renderer/**/*",
      "node_modules/ws/**/*",
      "node_modules/marked/**/*",
      "node_modules/uuid/**/*",
      "node_modules/openclaw/**/*"
    ],
    "asarUnpack": [
      "node_modules/openclaw/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "OpenAutomation.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "artifactName": "OpenAutomation-Mac.dmg"
    }
  }
}
